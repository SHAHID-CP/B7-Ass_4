# Server port number the app will listen on
PORT=

# Environment mode: development / production / test
NODE_ENV=

# Base URL of the frontend app (used for Stripe success/cancel redirect URLs)
APP_URL=

# Postgres connection string (Prisma format: postgresql://user:password@host:port/dbname?schema=public)
DATABASE_URL=

# Secret key used to sign JWT access tokens
JWT_ACCESS_SECRET=

# Access token expiry duration (jsonwebtoken format, e.g. time string like "15m", "1h", "7d")
JWT_ACCESS_EXPIRES_IN=

# Secret key used to sign JWT refresh tokens (must be different from access secret)
JWT_REFRESH_SECRET=

# Refresh token expiry duration (jsonwebtoken format, e.g. time string like "15m", "1h", "7d")
JWT_REFRESH_EXPIRES_IN=

# Number of salt rounds for bcrypt password hashing (higher = slower but more secure)
BCRYPT_SALT_ROUNDS=

# Stripe
# Secret API key from Stripe dashboard (test mode key while developing)
STRIPE_SECRET_KEY=

# Signing secret used to verify Stripe webhook requests (from Stripe dashboard or `stripe listen` CLI output)
STRIPE_WEBHOOK_SECRET=