model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phoneNumber  String?
  profileImage String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties     Property[]      @relation("LandlordProperties")
  rentalRequests RentalRequest[] @relation("TenantRentals")
  reviews        Review[]

  @@map("users")
}
